{
  "name": "RunSpot Seoul - 서울 런닝 코스 가이드",
  "short_name": "RunSpot",
  "description": "서울의 아름다운 런닝 코스를 발견하고 기록하세요. GPS 추적, 코스 추천, 제휴 스팟 혜택까지!",
  "version": "1.0.0",
  "manifest_version": 3,
  
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#00FF88",
  "background_color": "#000000",
  
  "icons": [
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  
  "categories": [
    "health",
    "fitness",
    "sports",
    "lifestyle"
  ],
  
  "lang": "ko-KR",
  "dir": "ltr",
  
  "shortcuts": [
    {
      "name": "런닝 시작",
      "short_name": "런닝",
      "description": "새로운 런닝을 시작합니다",
      "url": "/running/start",
      "icons": [
        {
          "src": "/icons/shortcut-running.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "코스 탐색",
      "short_name": "코스",
      "description": "새로운 런닝 코스를 찾아보세요",
      "url": "/courses",
      "icons": [
        {
          "src": "/icons/shortcut-courses.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "제휴 스팟",
      "short_name": "스팟",
      "description": "제휴 스팟 혜택을 확인하세요",
      "url": "/spots",
      "icons": [
        {
          "src": "/icons/shortcut-spots.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "런닝 기록",
      "short_name": "기록",
      "description": "나의 런닝 기록을 확인하세요",
      "url": "/profile/records",
      "icons": [
        {
          "src": "/icons/shortcut-records.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  
  "screenshots": [
    {
      "src": "/screenshots/home-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "platform": "narrow",
      "label": "RunSpot 홈 화면"
    },
    {
      "src": "/screenshots/running-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "platform": "narrow",
      "label": "GPS 런닝 추적"
    },
    {
      "src": "/screenshots/courses-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "platform": "narrow",
      "label": "런닝 코스 탐색"
    },
    {
      "src": "/screenshots/home-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "platform": "wide",
      "label": "RunSpot 데스크톱 화면"
    }
  ],
  
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.runspot.seoul",
      "id": "com.runspot.seoul"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/runspot-seoul/id123456789",
      "id": "123456789"
    }
  ],
  
  "prefer_related_applications": false,
  
  "protocol_handlers": [
    {
      "protocol": "runspot",
      "url": "/?action=%s"
    }
  ],
  
  "file_handlers": [
    {
      "action": "/import-gpx",
      "accept": {
        "application/gpx+xml": [".gpx"],
        "application/tcx+xml": [".tcx"]
      }
    }
  ],
  
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "image",
          "accept": ["image/jpeg", "image/png", "image/webp"]
        }
      ]
    }
  },
  
  "permissions": [
    "geolocation",
    "notifications",
    "camera",
    "microphone",
    "storage-access",
    "background-sync",
    "persistent-storage"
  ],
  
  "features": [
    "CrossOriginIsolated"
  ],
  
  "edge_side_panel": {
    "preferred_width": 400
  },
  
  "launch_handler": {
    "client_mode": "navigate-existing"
  }
}
