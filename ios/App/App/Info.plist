	<!-- 런닝 관련 특수 권한 -->
	<key>NSLocationTemporaryUsageDescriptionDictionary</key>
	<dict>
		<key>RunningTrack</key>
		<string>런닝 추적을 위해 임시로 정확한 위치 정보가 필요합니다.</string>
		<key>CourseRecommendation</key>
		<string>주변 런닝 코스 추천을 위해 현재 위치 정보가 필요합니다.</string>
	</dict>

	<!-- 센서 권한 -->
	<key>NSFallDetectionUsageDescription</key>
	<string>RunSpot에서 런닝 중 안전을 위해 낙상 감지 기능을 제공합니다.</string>

	<!-- 음성 인식 권한 -->
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>RunSpot에서 음성 명령으로 런닝 기록을 제어할 수 있습니다.</string>

	<!-- 미디어 라이브러리 권한 -->
	<key>NSAppleMusicUsageDescription</key>
	<string>RunSpot에서 런닝 중 음악 재생을 위해 음악 라이브러리에 접근합니다.</string>

	<!-- 홈킷 권한 (스마트 홈 연동) -->
	<key>NSHomeKitUsageDescription</key>
	<string>RunSpot에서 스마트 홈 기기와 연동하여 런닝 환경을 최적화합니다.</string>

	<!-- 시리 권한 -->
	<key>NSSiriUsageDescription</key>
	<string>RunSpot에서 시리를 통해 런닝 기록을 시작하고 조회할 수 있습니다.</string>

	<!-- 페이스 ID / 터치 ID 권한 -->
	<key>NSFaceIDUsageDescription</key>
	<string>RunSpot에서 안전한 로그인을 위해 Face ID를 사용합니다.</string>

	<!-- 광고 추적 권한 (iOS 14.5+) -->
	<key>NSUserTrackingUsageDescription</key>
	<string>RunSpot에서 맞춤형 광고 및 서비스 개선을 위해 사용됩니다. 거부하셔도 앱 사용에 문제없습니다.</string>

